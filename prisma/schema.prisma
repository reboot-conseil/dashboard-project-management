generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum StatutProjet {
  PLANIFIE
  EN_COURS
  EN_PAUSE
  TERMINE
}

enum StatutEtape {
  A_FAIRE
  EN_COURS
  VALIDEE
}

enum Role {
  ADMIN
  PM
  CONSULTANT
}

model Consultant {
  id                     Int        @id @default(autoincrement())
  nom                    String
  email                  String     @unique
  tjm                    Decimal?
  coutJournalierEmployeur Float?
  competences            String?
  couleur                String     @default("#8B5CF6")
  actif                       Boolean    @default(true)
  crakotteConsultantId        String?    @unique
  resolvedPendingProjects     CrakottePendingProject[]
  password                    String?
  role                        Role       @default(CONSULTANT)
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  activites              Activite[]
}

model Projet {
  id                  Int                @id @default(autoincrement())
  nom                 String
  client              String
  budget              Decimal?
  chargeEstimeeTotale Float?
  dateDebut           DateTime?
  dateFin             DateTime?
  statut              StatutProjet       @default(PLANIFIE)
  couleur             String             @default("#3b82f6")
  crakotteProjectId   String?            @unique
  pendingCrakotte     CrakottePendingProject[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  activites           Activite[]
  etapes              Etape[]
  teamsConfig         ProjetTeamsConfig?
  documentsSource     DocumentIngestion[]
}

model Activite {
  id               Int        @id @default(autoincrement())
  consultantId     Int
  projetId         Int?
  etapeId          Int?
  date             DateTime
  heures           Decimal
  description      String?
  facturable       Boolean    @default(true)
  source           String     @default("MANUEL")
  crakotteEntryId  String?    @unique
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  consultant       Consultant @relation(fields: [consultantId], references: [id])
  projet           Projet?    @relation(fields: [projetId], references: [id])
  etape            Etape?     @relation(fields: [etapeId], references: [id])

  @@index([consultantId])
  @@index([projetId])
  @@index([etapeId])
}

model Etape {
  id                  Int         @id @default(autoincrement())
  projetId            Int
  nom                 String
  description         String?
  statut              StatutEtape @default(A_FAIRE)
  dateDebut           DateTime?
  deadline            DateTime?
  chargeEstimeeJours  Float?
  ordre               Int
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  projet              Projet      @relation(fields: [projetId], references: [id])
  activites           Activite[]

  @@index([projetId])
}

model ProjetTeamsConfig {
  id          Int      @id @default(autoincrement())
  projetId    Int      @unique
  projet      Projet   @relation(fields: [projetId], references: [id], onDelete: Cascade)

  // Canal Teams
  canalNom    String?  // Ex: "refonte-site-web" ou "#refonte-site-web"
  canalId     String?  // ID Teams du canal (optionnel)
  webhookUrl  String?  // URL webhook sortant Teams pour ce canal

  // Configuration
  logAutoActif Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DocumentIngestion {
  id             Int       @id @default(autoincrement())
  filename       String
  filepath       String
  filesize       Int?
  mimetype       String?
  type           String?   // devis, presentation, transcript, compte_rendu, email, autre
  status         String    @default("UPLOADING")
  // Statuts : UPLOADING, EXTRACTING, ANALYZING, PENDING_REVIEW, PROCESSED, REJECTED, ERROR

  projetId       Int?
  projet         Projet?   @relation(fields: [projetId], references: [id])

  extractedText  String?
  analysis       Json?
  confidence     Int?
  validatedData  Json?

  errorMessage   String?

  createdAt      DateTime  @default(now())
  processedAt    DateTime?

  @@index([status])
  @@index([createdAt])
}

model IntegrationConfig {
  id            Int       @id @default(autoincrement())

  // Configuration globale
  n8nUrl        String    @default("https://n8n.spoton-ai.fr")
  webhookSecret String
  emailDomain   String    @default("@reboot-conseil.com")

  // Statut
  actif         Boolean   @default(true)
  derniereSync  DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model CrakotteConfig {
  id            Int       @id @default(autoincrement())
  apiKey        String
  actif         Boolean   @default(true)
  dateDebutSync DateTime
  lastSyncAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model CrakotteSyncLog {
  id                  Int       @id @default(autoincrement())
  startedAt           DateTime
  finishedAt          DateTime?
  status              String
  activitesCreees     Int       @default(0)
  conflitsDetectes    Int       @default(0)
  nouveauxProjets     Int       @default(0)
  consultantsSkippes  Int       @default(0)
  errorMessage        String?
  createdAt           DateTime  @default(now())
}

model CrakotteConflict {
  id                 Int       @id @default(autoincrement())
  crakotteActiviteId Int
  manuelActiviteId   Int
  resolved           Boolean   @default(false)
  resolvedAt         DateTime?
  resolvedById       Int?
  keptSource         String?
  createdAt          DateTime  @default(now())
}

model CrakottePendingProject {
  id                   Int         @id @default(autoincrement())
  crakotteProjectId    String      @unique
  crakotteProjectName  String
  crakotteCustomerId   String
  crakotteCustomerName String
  suggestedProjetId    Int?
  suggestedProjet      Projet?     @relation(fields: [suggestedProjetId], references: [id])
  status               String      @default("PENDING")
  createdAt            DateTime    @default(now())
  resolvedAt           DateTime?
  resolvedById         Int?
  resolvedBy           Consultant? @relation(fields: [resolvedById], references: [id])
}
